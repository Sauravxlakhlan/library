<%- include('../partials/head') %>

<div class="min-h-screen bg-[#0F172A] font-sans antialiased text-slate-300 selection:bg-indigo-500/30">
    <nav class="border-b border-slate-800 bg-[#0F172A]/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-[1600px] mx-auto px-8 h-14 flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-6 bg-indigo-500 rounded-full"></div>
                    <h1 class="text-[10px] font-black uppercase tracking-[0.3em] text-white">Library Management</h1>
                </div>
                <div class="hidden md:flex gap-6 border-l border-slate-800 pl-6">
                    <a href="/admin/dashboard" class="text-[10px] font-bold uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors">Registry</a>
                    <a href="/admin/students" class="text-[10px] font-bold uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors">Directory</a>
                    <a href="/admin/books" class="text-[10px] font-bold uppercase tracking-widest text-indigo-400">Assets</a>
                </div>
            </div>
            <a href="/auth/logout" class="text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-md border border-slate-800 hover:bg-rose-500/10 hover:text-rose-400 hover:border-rose-500/50 transition-all">Logout</a>
        </div>
    </nav>

    <main class="max-w-[1600px] mx-auto p-10">
        <header class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 mb-12">
            <div>
                <h2 class="text-5xl font-black text-white tracking-tighter mb-2 uppercase italic">Asset Inventory</h2>
                <div class="flex items-center gap-4">
                    <p class="text-slate-500 text-xs font-medium uppercase tracking-[0.2em]">Active Nodes:</p>
                    <span class="bg-indigo-500/10 text-indigo-400 px-3 py-0.5 rounded text-[10px] font-black border border-indigo-500/20"><%= books.length %> Units</span>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">
                <div class="relative group w-full sm:w-80">
                    <input type="text" id="assetSearch" placeholder="SEARCH TITLE OR SN..." 
                           class="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-12 py-3 text-[10px] font-mono font-bold tracking-widest text-white outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all placeholder:text-slate-600 uppercase">
                    <svg class="w-4 h-4 absolute left-4 top-3 text-slate-500 group-focus-within:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>

                <a href="/admin/add-book" class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3.5 rounded-xl font-black text-[10px] uppercase tracking-widest shadow-lg shadow-indigo-500/20 transition-all flex items-center justify-center gap-3">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/></svg>
                    Register New Asset
                </a>
            </div>
        </header>

        <div id="assetGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
            <% books.forEach(book => { %>
                <div class="asset-card group bg-slate-900/40 border <%= book.status === 'Inactive' ? 'border-rose-900/30 grayscale opacity-60' : 'border-slate-800' %> rounded-[1.5rem] p-4 hover:border-indigo-500/40 hover:bg-slate-900/60 transition-all duration-500 relative overflow-hidden flex flex-col">
                    
                    <div class="absolute top-4 right-4 z-10">
                        <% if(book.status === 'Inactive') { %>
                            <span class="bg-rose-500/10 text-rose-500 text-[7px] font-black px-2 py-0.5 rounded-full border border-rose-500/20 uppercase tracking-widest">Offline</span>
                        <% } else { %>
                            <span class="bg-emerald-500/10 text-emerald-500 text-[7px] font-black px-2 py-0.5 rounded-full border border-emerald-500/20 uppercase tracking-widest">Active</span>
                        <% } %>
                    </div>

                    <div class="relative aspect-[2/3] rounded-xl overflow-hidden mb-4 bg-slate-950 shadow-xl mx-auto w-full max-w-[180px]">
                        <img src="/uploads/<%= book.image %>" onerror="this.src='/images/default-book.png'" class="w-full h-full object-cover transition-all duration-700 opacity-90 group-hover:opacity-100 group-hover:scale-105">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent opacity-40"></div>
                    </div>

                    <div class="space-y-1 text-center flex-grow">
                        <h3 class="asset-title text-sm font-black text-white uppercase tracking-tight truncate px-2"><%= book.title %></h3>
                        <p class="text-[8px] font-mono text-slate-500 uppercase tracking-widest"><%= book.author %></p>
                        
                        <div class="flex items-center justify-center gap-2 pt-2">
                            <span class="text-[8px] font-mono text-indigo-400 font-bold opacity-60">SN: <%= book.serialNumber %></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-t border-slate-800/50">
                        <form action="/admin/books/toggle-status/<%= book._id %>" method="POST">
                            <button type="submit" class="w-full py-2.5 rounded-lg text-[8px] font-black uppercase tracking-[0.2em] transition-all flex items-center justify-center gap-2 
                                <%= book.status === 'Inactive' ? 'bg-emerald-600 hover:bg-emerald-500 shadow-emerald-500/10' : 'bg-slate-800 hover:bg-rose-600 shadow-black' %> text-white shadow-lg">
                                <%= book.status === 'Inactive' ? 'Enable' : 'Disable' %>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>

        <div id="paginationContainer" class="mt-16 flex justify-center items-center gap-8">
            <button id="prevBtn" class="flex items-center gap-2 px-6 py-2.5 bg-slate-950 border border-slate-800 rounded-xl text-[9px] font-black uppercase tracking-widest text-slate-500 hover:border-indigo-500/50 hover:text-white transition-all disabled:opacity-20 disabled:cursor-not-allowed group">
                <svg class="w-3 h-3 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
                Previous
            </button>

            <div class="px-4 py-2 bg-slate-900/50 border border-slate-800 rounded-lg">
                <span class="text-[9px] font-mono font-bold text-indigo-400 uppercase tracking-widest">
                    Sector <span id="currentPageDisplay">1</span> / <span id="totalPagesDisplay">1</span>
                </span>
            </div>

            <button id="nextBtn" class="flex items-center gap-2 px-6 py-2.5 bg-slate-950 border border-slate-800 rounded-xl text-[9px] font-black uppercase tracking-widest text-slate-500 hover:border-indigo-500/50 hover:text-white transition-all disabled:opacity-20 disabled:cursor-not-allowed group">
                Next
                <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
            </button>
        </div>
    </main>
</div>

<script>
    const ITEMS_PER_PAGE = 3; // More items per page since cards are smaller
    let currentPage = 1;
    let filteredAssets = [];

    const assetSearch = document.getElementById('assetSearch');
    const allCards = Array.from(document.querySelectorAll('.asset-card'));
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const currentPageDisplay = document.getElementById('currentPageDisplay');
    const totalPagesDisplay = document.getElementById('totalPagesDisplay');
    const paginationContainer = document.getElementById('paginationContainer');

    function updateInventory() {
        const totalAssets = filteredAssets.length;
        const totalPages = Math.ceil(totalAssets / ITEMS_PER_PAGE);
        
        if (currentPage > totalPages) currentPage = totalPages || 1;

        const startIdx = (currentPage - 1) * ITEMS_PER_PAGE;
        const endIdx = startIdx + ITEMS_PER_PAGE;

        allCards.forEach(card => card.style.display = "none");
        
        filteredAssets.slice(startIdx, endIdx).forEach(card => {
            card.style.display = "flex";
        });

        currentPageDisplay.innerText = currentPage;
        totalPagesDisplay.innerText = totalPages || 1;

        prevBtn.disabled = (currentPage <= 1);
        nextBtn.disabled = (currentPage >= totalPages || totalAssets === 0);

        paginationContainer.style.display = (totalPages <= 1) ? 'none' : 'flex';
    }

    assetSearch.addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase().trim();
        
        filteredAssets = allCards.filter(card => {
            const title = card.querySelector('.asset-title').textContent.toLowerCase();
            const author = card.querySelector('.font-mono').textContent.toLowerCase();
            return title.includes(query) || author.includes(query);
        });

        currentPage = 1;
        updateInventory();
    });

    prevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
            currentPage--;
            updateInventory();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });

    nextBtn.addEventListener('click', () => {
        const totalPages = Math.ceil(filteredAssets.length / ITEMS_PER_PAGE);
        if (currentPage < totalPages) {
            currentPage++;
            updateInventory();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });

    // Init
    filteredAssets = [...allCards];
    updateInventory();
</script>