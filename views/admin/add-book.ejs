<%- include('../partials/head') %>

<div class="min-h-screen bg-[#0F172A] font-sans antialiased text-slate-300 selection:bg-indigo-500/30">
    <nav class="border-b border-slate-800 bg-[#0F172A]/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-[1600px] mx-auto px-8 h-14 flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-6 bg-indigo-500 rounded-full"></div>
                    <h1 class="text-[10px] font-black uppercase tracking-[0.3em] text-white">Library Management <span class="text-slate-500"></span></h1>
                </div>
                <div class="hidden md:flex gap-6 border-l border-slate-800 pl-6 text-[10px] font-bold uppercase tracking-widest">
                    <a href="/admin/dashboard" class="text-slate-500 hover:text-slate-300 transition-colors">Registry</a>
                    <a href="/admin/students" class="text-slate-500 hover:text-slate-300 transition-colors">Directory</a>
                    <span class="text-indigo-400">Add Asset</span>
                </div>
            </div>

            <a href="/admin/dashboard" class="text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-md border border-slate-800 hover:bg-indigo-500/10 hover:text-indigo-400 hover:border-indigo-500/50 transition-all flex items-center gap-2">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Dashboard
            </a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto py-16 px-6">
        <div class="mb-10">
            <h2 class="text-4xl font-black text-white tracking-tighter">New Asset Registration.</h2>
            <p class="text-slate-500 text-[10px] font-black uppercase tracking-[0.3em] mt-2">Inventory Management Protocol </p>
        </div>

        <div class="bg-[#1E293B] rounded-3xl border border-slate-800 shadow-2xl overflow-hidden">
            <div class="bg-slate-900/50 px-10 py-6 border-b border-slate-800 flex justify-between items-center">
                <span class="text-[9px] font-black text-indigo-400 uppercase tracking-widest flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                    System Ready for Ingestion
                </span>
            </div>

            <form action="/admin/add-book" method="POST" enctype="multipart/form-data" class="p-10 space-y-10">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">
                    <div class="md:col-span-2 group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Digital Asset Label (Title)</label>
                        <input type="text" name="title" required 
                               class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-bold text-white placeholder:text-slate-700 shadow-inner" 
                               placeholder="Enter asset title...">
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Identification Hash (SN)</label>
                        <input type="text" name="serialNumber" required 
                               class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-mono font-bold text-indigo-400 placeholder:text-slate-700 shadow-inner" 
                               placeholder="SN-0000-0000">
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Origin Contributor</label>
                        <input type="text" name="author" required 
                               class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-bold text-slate-200 placeholder:text-slate-700 shadow-inner" 
                               placeholder="Primary Author">
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Volume Metrics (Pages)</label>
                        <input type="number" name="pages" required 
                               class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-bold text-slate-200 placeholder:text-slate-700 shadow-inner" 
                               placeholder="000">
                    </div>

                    <div class="group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Classification</label>
                        <select class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-bold text-slate-200 shadow-inner appearance-none cursor-pointer">
                            <option class="bg-slate-900">Academic / Research</option>
                            <option class="bg-slate-900">Institutional Resource</option>
                            <option class="bg-slate-900">General Literature</option>
                        </select>
                    </div>

                    <div class="md:col-span-2 group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Abstract / Summary</label>
                        <textarea name="description" rows="4" required
                                  class="w-full px-6 py-4 bg-slate-900/50 border border-slate-700 rounded-xl focus:bg-slate-900 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all font-medium text-slate-300 placeholder:text-slate-700 shadow-inner leading-relaxed"
                                  placeholder="Provide technical summary..."></textarea>
                    </div>

                    <div class="md:col-span-2 group">
                        <label class="block text-[9px] font-black text-slate-500 uppercase tracking-[0.2em] mb-3 group-focus-within:text-indigo-400 transition-colors">Visual Verification (Cover)</label>
                        <label class="relative flex flex-col items-center justify-center w-full h-44 bg-slate-900/30 border-2 border-dashed border-slate-700 rounded-2xl cursor-pointer hover:bg-slate-900/60 hover:border-indigo-500/50 transition-all group/upload overflow-hidden">
                            <div class="flex flex-col items-center justify-center">
                                <svg class="w-6 h-6 text-slate-500 mb-2 group-hover/upload:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                                <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Upload Asset Image</p>
                            </div>
                            <input type="file" name="bookImage" class="hidden" required />
                        </label>
                    </div>
                </div>

                <div class="pt-6">
                    <button type="submit" 
                            class="w-full bg-indigo-600 text-white font-black py-5 rounded-xl shadow-lg shadow-indigo-600/10 hover:bg-white hover:text-black transition-all duration-300 transform active:scale-[0.98] uppercase tracking-[0.4em] text-[10px]">
                        Commit to Database
                    </button>
                    <p class="text-center text-[8px] text-slate-600 font-bold uppercase tracking-[0.3em] mt-8 opacity-40">
                        Secure Submission Protocol Active • Local Node: Library_01
                    </p>
                </div>
            </form>
        </div>
    </main>
</div>