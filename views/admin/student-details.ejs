<%- include('../partials/head') %>

<div class="min-h-screen bg-[#0F172A] font-sans antialiased text-slate-300 selection:bg-indigo-500/30">
    
    <nav class="border-b border-slate-800 bg-[#0F172A]/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-[1600px] mx-auto px-8 h-14 flex justify-between items-center">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <div class="w-2 h-6 bg-indigo-500 rounded-full"></div>
                    <h1 class="text-[10px] font-black uppercase tracking-[0.3em] text-white">Library Management <span class="text-slate-500">OS</span></h1>
                </div>
                <div class="h-4 w-[1px] bg-slate-800"></div>
                <span class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Entity Dossier</span>
            </div>
            <a href="/admin/students" class="text-[9px] font-black uppercase tracking-widest px-4 py-1.5 rounded-md border border-slate-800 hover:bg-indigo-500/10 hover:text-indigo-400 transition-all flex items-center gap-2">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Return to Directory
            </a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-8 py-12">
        
        <div class="bg-[#1E293B] rounded-[40px] border border-slate-800 shadow-2xl p-10 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-96 h-96 bg-indigo-600/10 rounded-full blur-[120px] -mr-32 -mt-32"></div>
            
            <div class="relative flex flex-col md:flex-row items-center gap-12">
                <div class="relative">
                    <div class="absolute inset-0 bg-indigo-500 rounded-[48px] blur-2xl opacity-20 animate-pulse"></div>
                    <img src="/uploads/<%= student.profileImage %>" 
                         onerror="this.src='/images/default-user.png'"
                         class="relative w-48 h-48 rounded-[48px] object-cover border-2 border-slate-700 p-1 bg-slate-800 shadow-2xl">
                    <div class="absolute -bottom-2 -right-2 bg-emerald-500 w-8 h-8 rounded-2xl border-4 border-[#1E293B] shadow-lg flex items-center justify-center">
                        <div class="w-2 h-2 bg-white rounded-full animate-ping"></div>
                    </div>
                </div>

                <div class="flex-1 text-center md:text-left">
                    <div class="flex flex-col md:flex-row md:items-center gap-4">
                        <h2 class="text-5xl font-black text-white tracking-tighter uppercase"><%= student.name %></h2>
                        <span class="w-fit mx-auto md:mx-0 bg-indigo-500/10 text-indigo-400 px-4 py-1 rounded-full text-[9px] font-black uppercase tracking-[0.2em] border border-indigo-500/20">
                            <%= student.role %>
                        </span>
                    </div>
                    <p class="text-slate-500 font-mono text-lg mt-2"><%= student.email %></p>
                    
                    <div class="mt-10 flex flex-wrap justify-center md:justify-start gap-4">
                        <div class="bg-slate-900/50 backdrop-blur-md px-6 py-4 rounded-3xl border border-slate-800 min-w-[160px]">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Liability Balance</p>
                            <p class="text-2xl font-bold text-rose-500 mt-1">₹<%= totalFine %></p>
                        </div>
                        <div class="bg-slate-900/50 backdrop-blur-md px-6 py-4 rounded-3xl border border-slate-800 min-w-[160px]">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Asset Lifecycle</p>
                            <p class="text-2xl font-bold text-white mt-1"><%= history.length %> <span class="text-xs text-slate-600 ml-1 uppercase">Units</span></p>
                        </div>
                        <div class="bg-slate-900/50 backdrop-blur-md px-6 py-4 rounded-3xl border border-slate-800 min-w-[160px]">
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest">Member ID</p>
                            <p class="text-xs font-mono font-bold text-indigo-400 mt-2 uppercase"><%= student._id.toString().slice(-12) %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-20">
            <div class="flex items-center gap-4 mb-8">
                <div class="w-10 h-[2px] bg-indigo-500"></div>
                <h3 class="text-xs font-black text-white tracking-[0.4em] uppercase">Transaction Audit Logs</h3>
            </div>

            <div class="bg-[#1E293B] rounded-[32px] border border-slate-800 shadow-2xl overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-900/50 text-[9px] font-black uppercase text-slate-500 tracking-[0.2em] border-b border-slate-800">
                            <th class="px-10 py-6">Operational Unit</th>
                            <th class="px-10 py-6">Current Status</th>
                            <th class="px-10 py-6 text-center">Fine (INR)</th>
                            <th class="px-10 py-6 text-right">Registry Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/50">
                        <% if(history.length > 0) { %>
                            <% history.forEach(item => { %>
                                <tr class="group hover:bg-slate-800/40 transition-all cursor-default">
                                    <td class="px-10 py-6 font-bold text-slate-200 text-sm group-hover:text-indigo-400 transition-colors">
                                        <%= item.bookTitle %>
                                    </td>
                                    <td class="px-10 py-6">
                                        <% if(item.status === 'Returned') { %>
                                            <span class="text-[8px] font-black uppercase tracking-widest text-slate-500 px-3 py-1 rounded bg-slate-900 border border-slate-800">
                                                Archived
                                            </span>
                                        <% } else { %>
                                            <span class="text-[8px] font-black uppercase tracking-widest text-emerald-400 px-3 py-1 rounded bg-emerald-500/10 border border-emerald-500/20">
                                                Active Loan
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-10 py-6 text-center font-mono font-bold <%= item.finalFine > 0 ? 'text-rose-500' : 'text-slate-700' %>">
                                        <%= item.finalFine || '0.00' %>
                                    </td>
                                    <td class="px-10 py-6 text-right text-[10px] text-slate-500 font-bold uppercase tracking-widest">
                                        <%= new Date(item.requestDate).toLocaleDateString('en-GB') %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="p-32 text-center">
                                    <p class="text-slate-700 font-black uppercase tracking-[0.5em] text-[10px]">Log Buffer Empty • No Historical Records</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <footer class="mt-20 py-12 border-t border-slate-800/50 bg-slate-900/20">
        <div class="max-w-[1600px] mx-auto px-10 flex justify-between items-center opacity-30">
            <p class="text-[9px] font-black uppercase tracking-[0.4em] text-slate-500">
                System Log Trace: 0x<%= student._id.toString().slice(-6).toUpperCase() %>
            </p>
            <div class="flex items-center gap-3">
                <span class="text-[9px] font-black uppercase text-slate-400 tracking-widest">Encrypted Session</span>
                <div class="w-1.5 h-1.5 rounded-full bg-indigo-500"></div>
            </div>
        </div>
    </footer>
</div>