# =========================
# System / Environment (CRITICAL)
# =========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Never track your secret environment variables
!.env.example

# =========================
# Node.js
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache

# =========================
# Library System Specifics (Uploads)
# =========================
# Ignore actual book/user images to keep the repo small
public/uploads/*
# Allow the folder to exist but stay empty on GitHub
!public/uploads/.gitkeep

# Express-session file store (if used)
sessions/

